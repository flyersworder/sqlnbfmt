    "query = \"\"\"\n",
    "WITH active_users AS (\n",
    "    SELECT\n",
    "      id,\n",
    "      name\n",
    "    FROM users\n",
    "    WHERE\n",
    "      active = 1\n",
    ")\n",
    "SELECT\n",
    "  *\n",
    "FROM active_users\n",
    "\"\"\""
