    "query = \"\"\"\n",
    "SELECT\n",
    "  u.id,\n",
    "  u.name,\n",
    "  o.total\n",
    "FROM users AS u\n",
    "INNER JOIN orders AS o\n",
    "  ON u.id = o.user_id\n",
    "LEFT JOIN addresses AS a\n",
    "  ON u.id = a.user_id\n",
    "\"\"\""
   ]
  }
