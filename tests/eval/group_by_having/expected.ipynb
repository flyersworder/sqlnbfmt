   "source": [
    "query = \"\"\"\n",
    "SELECT\n",
    "  department,\n",
    "  COUNT(*) AS cnt,\n",
    "  AVG(salary) AS avg_salary\n",
    "FROM employees\n",
    "GROUP BY\n",
    "  department\n",
    "HAVING\n",
    "  COUNT(*) > 5\n",
    "ORDER BY\n",
    "  avg_salary DESC\n",
    "\"\"\""
   ]
  }
 ],
